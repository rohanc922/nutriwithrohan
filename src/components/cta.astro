---
import Link from "./ui/link.astro";
---

<section class="mt-24 max-w-5xl mx-auto px-5">
  <div
    class="relative overflow-hidden rounded-3xl bg-brand-700 text-cream-50 px-8 md:px-16 py-16 md:py-20 flex flex-col items-center text-center">
    <div
      aria-hidden="true"
      class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-brand-500/40 blur-3xl">
    </div>
    <div
      aria-hidden="true"
      class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-accent-500/20 blur-3xl">
    </div>

    <p class="text-xs font-medium tracking-widest uppercase text-brand-200">
      Ready to start?
    </p>
    <h2
      class="mt-3 font-serif text-4xl md:text-5xl font-semibold tracking-tight max-w-2xl">
      Your nutrition plan, built around your real life.
    </h2>
    <p class="mt-5 text-lg text-cream-200/80 max-w-xl">
      Book an introductory consultation. We'll talk through your goals, your
      medical history, and what a sustainable plan looks like for you.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <Link href="/book" style="inverted">Book a Consultation</Link>
      <Link href="/pricing" style="outline" class="!border-cream-50/40 !text-cream-50 hover:!bg-cream-50/10">
        See Programmes
      </Link>
    </div>
  </div>
</section>
