---

<section id="services" class="mt-12 lg:mt-24 max-w-6xl mx-auto">
  <div class="max-w-2xl">
    <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
      What we do
    </p>
    <h2 class="mt-3 font-serif text-4xl lg:text-5xl font-semibold text-ink-900 tracking-tight">
      Discovering the journey to wellness, with you.
    </h2>
    <p class="mt-5 text-lg text-ink-500 leading-relaxed">
      Programmes rooted in evidence, tailored to your body and your routine.
      Choose what fits, or talk to Rohan about a custom plan.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
    {
      services.map((s) => (
        <article class="group p-6 rounded-2xl bg-cream-50 border border-cream-300 hover:border-brand-200 hover:shadow-md transition">
          <div class="w-11 h-11 rounded-full bg-brand-50 flex items-center justify-center text-brand-600 group-hover:bg-brand-500 group-hover:text-cream-50 transition">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5">
              <path d={s.icon} />
              {s.iconExtra && <path d={s.iconExtra} />}
            </svg>
          </div>
          <h3 class="mt-5 font-serif text-xl font-semibold text-ink-900">
            {s.title}
          </h3>
          <p class="mt-2 text-ink-500 leading-relaxed">{s.description}</p>
        </article>
      ))
    }
  </div>
</section>
