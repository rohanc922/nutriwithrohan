  },
  {
    title: "Global Nutrition",
    description:
      "Designed for clients living outside India. Indian and international food integrated seamlessly, with travel and dining-out guidance.",
    icon: "M2 12a10 10 0 1 0 20 0 10 10 0 1 0 -20 0M2 12h20M12 2a15 15 0 0 1 4 10 15 15 0 0 1 -4 10 15 15 0 0 1 -4 -10 15 15 0 0 1 4 -10z",
  },
  {
    title: "Sports Nutrition",
    description:
      "Performance-tuned plans for athletes — fueling for endurance, recovery, joint mobility, pre-event meals, and supplementation strategy.",
    icon: "M6.5 6.5L17.5 17.5M17.5 6.5L6.5 17.5M12 2v4M12 18v4M2 12h4M18 12h4",
  },
  {
    title: "Gut Health",
    description:
      "Anti-inflammatory meal plans, gut-replenishing foods, and elimination protocols for IBS, bloating, and chronic digestive issues.",
    icon: "M12 2a8 8 0 0 0 -8 8c0 6 8 12 8 12s8-6 8-12a8 8 0 0 0 -8 -8zM12 6a4 4 0 0 1 4 4",
