---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-cream-300 bg-cream-50">
  <div class="max-w-6xl mx-auto px-5 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <a href="/" class="flex items-center gap-2">
        <span
          class="inline-block w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4 text-cream-50">
            <path
              d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.5.66c1 6.07-1.18 13.07-7.31 14.78A7 7 0 0 1 11 20Z"
            ></path>
            <path d="M2 21c0-3 1.85-5.36 5.08-6"></path>
          </svg>
        </span>
        <span class="font-serif text-lg">
          <span class="text-brand-700 font-semibold">Nutri</span><span
            class="text-ink-500">withRohan</span>
        </span>
      </a>
      <p class="mt-3 text-sm text-ink-500 leading-relaxed max-w-xs">
        Personalized nutrition coaching grounded in evidence and tailored to
        your life.
      </p>
    </div>
    <div>
      <h4 class="font-serif font-semibold text-ink-700">Explore</h4>
      <ul class="mt-3 space-y-2 text-sm text-ink-500">
        <li><a href="/philosophy" class="hover:text-brand-600">Philosophy</a></li>
        <li><a href="/pricing" class="hover:text-brand-600">Pricing & Plans</a></li>
        <li><a href="/blog" class="hover:text-brand-600">Resources</a></li>
        <li><a href="/contact" class="hover:text-brand-600">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-serif font-semibold text-ink-700">Get Started</h4>
      <ul class="mt-3 space-y-2 text-sm text-ink-500">
        <li><a href="/book" class="hover:text-brand-600">Book a consultation</a></li>
        <li>
          <a href="mailto:rohanc922@gmail.com" class="hover:text-brand-600">
            rohanc922@gmail.com
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-cream-300">
    <p class="max-w-6xl mx-auto px-5 py-5 text-center text-xs text-ink-400">
      © {year} NutriwithRohan. All rights reserved.
    </p>
  </div>
</footer>
