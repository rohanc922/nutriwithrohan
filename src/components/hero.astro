---
import Link from "@/components/ui/link.astro";
import { Image } from "astro:assets";
import rohanPortrait from "@/assets/rohan-portrait.png";
---

<section class="relative">

  <div class="grid lg:grid-cols-12 gap-12 items-center pt-12 pb-20 md:pt-20 md:pb-28">
    <div class="lg:col-span-7 max-w-2xl">
      <span
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium tracking-wide uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
        Evidence-based nutrition coaching
      </span>
      <h1
        class="mt-5 font-serif text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-semibold text-ink-900 tracking-tight leading-[1.02]">
        Elevate your <em class="text-brand-600 font-normal italic">well-being</em>.
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-ink-500 leading-relaxed max-w-xl">
        Empowering you to achieve optimal health through personalized
        nutrition plans and lifestyle changes — modern nutrition science
        rooted in Indian food and global lifestyles.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <Link href="/book">Book a Consultation</Link>
        <Link href="/philosophy" style="outline">Learn More</Link>
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="relative max-w-md mx-auto lg:max-w-none">
        <div
          aria-hidden="true"
          class="absolute -inset-4 bg-brand-500/10 rounded-3xl rotate-3 -z-10">
        </div>
        <Image
          src={rohanPortrait}
          alt="Rohan, certified nutrition coach"
          widths={[480, 640, 800, 1024]}
          sizes="(max-width: 1024px) 90vw, 480px"
          loading="eager"
          fetchpriority="high"
          format="avif"
          quality={82}
          class="relative w-full h-auto rounded-2xl shadow-xl object-cover"
        />
      </div>
    </div>
  </div>
</section>
