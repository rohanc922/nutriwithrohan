---
// Multi-layer moving background for the home page.
// Layer 1: soft mesh gradient that slowly pulses opacity
// Layer 2: 6 large blurred organic shapes drifting across the viewport
// Layer 3: small floating dots / particles (orbs)
//
// Position: fixed — persists across the whole page as the user scrolls,
// creating an ambient parallax-like effect.
//
// Respects prefers-reduced-motion (all animation paused).
// Pure CSS, no JS, no external assets.
---

<div class="ambient-bg" aria-hidden="true">
  <div class="mesh"></div>
  <span class="blob b1"></span>
  <span class="blob b2"></span>
  <span class="blob b3"></span>
  <span class="blob b4"></span>
  <span class="blob b5"></span>
  <span class="blob b6"></span>
  <span class="orb o1"></span>
  <span class="orb o2"></span>
  <span class="orb o3"></span>
  <span class="orb o4"></span>
  <span class="orb o5"></span>
</div>

<style>
  .ambient-bg {
    /* position: fixed so it persists across scroll. inset: 0 fills the viewport.
       z-index: -1 places it behind sibling content, but the body must be
       TRANSPARENT for it to be visible (otherwise the body background hides it). */
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: -1;
  }

  /* Layer 1: soft pulsing mesh gradient — multiple soft radials. */
  .mesh {
    position: absolute;
    inset: -10%;
    background:
      radial-gradient(circle at 18% 22%, var(--color-brand-100) 0%, transparent 38%),
      radial-gradient(circle at 82% 30%, var(--color-accent-500) 0%, transparent 32%),
      radial-gradient(circle at 70% 78%, var(--color-brand-200) 0%, transparent 42%),
      radial-gradient(circle at 28% 80%, var(--color-cream-300) 0%, transparent 36%);
    opacity: 0.55;
    animation: mesh-pulse 24s ease-in-out infinite alternate;
    will-change: transform, opacity;
  }

  /* Layer 2: drifting blurred organic shapes. */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    will-change: transform;
  }
  .b1 {
    width: 36rem;
    height: 36rem;
    top: -10rem;
    left: -8rem;
    background: var(--color-brand-200);
    opacity: 0.55;
    animation: drift-1 26s ease-in-out infinite alternate;
  }
  .b2 {
    width: 30rem;
    height: 30rem;
    top: 12%;
    right: -10rem;
    background: var(--color-accent-500);
    opacity: 0.32;
    animation: drift-2 32s ease-in-out infinite alternate;
  }
  .b3 {
    width: 28rem;
    height: 28rem;
    top: 50%;
    left: 38%;
    background: var(--color-brand-300);
    opacity: 0.28;
    animation: drift-3 38s ease-in-out infinite alternate;
  }
  .b4 {
    width: 24rem;
    height: 24rem;
    bottom: -6rem;
    left: 18%;
    background: var(--color-brand-100);
    opacity: 0.65;
    animation: drift-4 30s ease-in-out infinite alternate;
  }
  .b5 {
    width: 26rem;
    height: 26rem;
    bottom: 6%;
    right: 14%;
    background: var(--color-cream-300);
    opacity: 0.45;
    animation: drift-5 42s ease-in-out infinite alternate;
  }
  .b6 {
    width: 20rem;
    height: 20rem;
    top: 30%;
    left: 8%;
    background: var(--color-accent-500);
    opacity: 0.18;
    animation: drift-6 36s ease-in-out infinite alternate;
  }

  /* Layer 3: small soft orbs that drift gently. */
  .orb {
    position: absolute;
    border-radius: 50%;
    background: var(--color-brand-500);
    filter: blur(2px);
    will-change: transform, opacity;
  }
  .o1 {
    width: 10px;
    height: 10px;
    top: 18%;
    left: 30%;
    opacity: 0.35;
    animation: orb-1 18s ease-in-out infinite alternate;
  }
  .o2 {
    width: 6px;
    height: 6px;
    top: 35%;
    right: 22%;
    opacity: 0.4;
    background: var(--color-accent-500);
    animation: orb-2 22s ease-in-out infinite alternate;
  }
  .o3 {
    width: 8px;
    height: 8px;
    bottom: 25%;
    left: 18%;
    opacity: 0.45;
    background: var(--color-brand-600);
    animation: orb-3 26s ease-in-out infinite alternate;
  }
  .o4 {
    width: 5px;
    height: 5px;
    top: 60%;
    right: 35%;
    opacity: 0.5;
    background: var(--color-brand-500);
    animation: orb-4 20s ease-in-out infinite alternate;
  }
  .o5 {
    width: 12px;
    height: 12px;
    top: 75%;
    left: 55%;
    opacity: 0.25;
    background: var(--color-accent-500);
    animation: orb-5 30s ease-in-out infinite alternate;
  }

  /* Drift keyframes — each blob takes its own diagonal path. */
  @keyframes drift-1 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(8rem, 5rem) scale(1.18); }
  }
  @keyframes drift-2 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-8rem, 6rem) scale(1.12); }
  }
  @keyframes drift-3 {
    0% { transform: translate(0, 0) scale(0.95); }
    100% { transform: translate(-6rem, -4rem) scale(1.15); }
  }
  @keyframes drift-4 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(7rem, -8rem) scale(0.9); }
  }
  @keyframes drift-5 {
    0% { transform: translate(0, 0) scale(1.05); }
    100% { transform: translate(-6rem, -5rem) scale(0.88); }
  }
  @keyframes drift-6 {
    0% { transform: translate(0, 0) scale(0.9); }
    100% { transform: translate(5rem, 4rem) scale(1.2); }
  }

  /* Mesh slowly breathes between two opacity / scale states. */
  @keyframes mesh-pulse {
    0% { opacity: 0.45; transform: scale(1); }
    100% { opacity: 0.65; transform: scale(1.05); }
  }

  /* Orbs drift gently with opacity flicker for an alive feel. */
  @keyframes orb-1 {
    0% { transform: translate(0, 0); opacity: 0.35; }
    100% { transform: translate(40px, -60px); opacity: 0.55; }
  }
  @keyframes orb-2 {
    0% { transform: translate(0, 0); opacity: 0.4; }
    100% { transform: translate(-50px, 50px); opacity: 0.6; }
  }
  @keyframes orb-3 {
    0% { transform: translate(0, 0); opacity: 0.45; }
    100% { transform: translate(60px, -30px); opacity: 0.25; }
  }
  @keyframes orb-4 {
    0% { transform: translate(0, 0); opacity: 0.5; }
    100% { transform: translate(-30px, -40px); opacity: 0.7; }
  }
  @keyframes orb-5 {
    0% { transform: translate(0, 0); opacity: 0.25; }
    100% { transform: translate(50px, 60px); opacity: 0.5; }
  }

  /* Respect users who prefer reduced motion. */
  @media (prefers-reduced-motion: reduce) {
    .blob,
    .orb,
    .mesh {
      animation: none !important;
    }
  }
</style>
