---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import BrandMark from "@/components/brandmark.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  { title: "Philosophy", path: "/philosophy" },
  { title: "Pricing & Plans", path: "/pricing" },
  { title: "Resources", path: "/blog" },
  { title: "Contact", path: "/contact" },
];
---

<Container>
  <header
    class="flex flex-col lg:flex-row justify-between items-center py-5 border-b border-cream-300">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-lg" aria-label="NutriwithRohan home">
          <span class="inline-block w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-4 h-4 text-cream-50">
              <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96a1 1 0 0 1 1.5.66c1 6.07-1.18 13.07-7.31 14.78A7 7 0 0 1 11 20Z" />
              <path d="M2 21c0-3 1.85-5.36 5.08-6" />
            </svg>
          </span>
          <BrandMark size="lg" />
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-5 h-5 text-ink-700" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-4 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-2 lg:items-center">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-4 py-2 items-center text-ink-500 hover:text-brand-600 transition-colors">
                  {item.title}
                </a>
              </li>
            ))
          }
          <li class="mt-3 lg:mt-0 lg:ml-3">
            <Link href="/book" size="md">Book Online</Link>
          </li>
        </ul>
      </MenuItems>
    </Astronav>
  </header>
</Container>
