---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page not found">
  <Container>
    <div class="min-h-[calc(100vh-16rem)] flex items-center justify-center text-center">
      <div class="max-w-md">
        <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
          404
        </p>
        <h1
          class="mt-3 font-serif text-5xl font-semibold text-ink-900 tracking-tight">
          We can't find that page.
        </h1>
        <p class="mt-4 text-ink-500 leading-relaxed">
          The page you're looking for may have moved. Try the home page or get
          in touch.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <Link href="/">Go home</Link>
          <Link href="/contact" style="outline">Contact us</Link>
        </div>
      </div>
    </div>
  </Container>
</Layout>
