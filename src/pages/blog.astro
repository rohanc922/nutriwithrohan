---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";

const posts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

posts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Layout
  title="Resources"
  description="Notes on nutrition, gut health, sports nutrition, and habits — written from real client work."
>
  <Container>
    <header class="max-w-2xl mx-auto text-center mt-12 lg:mt-20">
      <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
        Resources
      </p>
      <h1
        class="mt-4 font-serif text-5xl lg:text-6xl font-semibold text-ink-900 tracking-tight">
        Some of the best resources for a healthy, fulfilled life.
      </h1>
      <p class="mt-5 text-lg text-ink-500 leading-relaxed">
        Notes from real client work — gut health, habits, sports nutrition,
        and travel-friendly eating.
      </p>
    </header>

    <ul class="grid gap-6 max-w-3xl mx-auto mt-14">
      {
        posts.length === 0 && (
          <li class="rounded-2xl bg-cream-50 border border-cream-300 p-8 text-center text-ink-500">
            <p class="font-serif text-2xl text-ink-700">Coming soon.</p>
            <p class="mt-2 text-sm">
              The first articles are being written. Check back soon.
            </p>
          </li>
        )
      }
      {
        posts.map((post) => (
          <li class="rounded-2xl bg-cream-50 border border-cream-300 hover:border-brand-200 hover:shadow-md transition">
            <a
              href={`/blog/${post.slug}`}
              class="block p-7 group">
              <span class="text-xs font-medium tracking-widest uppercase text-brand-600">
                {post.data.category}
              </span>
              <h2 class="mt-2 font-serif text-2xl md:text-3xl font-semibold text-ink-900 group-hover:text-brand-700 transition">
                {post.data.title}
              </h2>
              <p class="mt-3 text-ink-500 leading-relaxed">{post.data.snippet}</p>
              <div class="mt-4 text-sm text-ink-400 flex items-center gap-2">
                <span>{post.data.author}</span>
                <span>·</span>
                <time datetime={post.data.publishDate.toISOString()}>
                  {post.data.publishDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Layout>
