---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Contact"
  description="Let's work on your health, wherever you are. Serving clients across the USA, Dubai, and Singapore from Bengaluru, India."
>
  <Container>
    <header class="max-w-3xl mx-auto text-center mt-12 lg:mt-20">
      <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
        Contact
      </p>
      <h1
        class="mt-4 font-serif text-5xl lg:text-6xl font-semibold text-ink-900 tracking-tight">
        Let's work on your health — wherever you are.
      </h1>
      <p class="mt-5 text-lg text-ink-500 leading-relaxed">
        Serving clients across the <strong class="text-ink-700">USA, Dubai, and Singapore</strong>,
        NutriwithRohan creates modern nutrition plans rooted in Indian food,
        global lifestyles, and real results. Drop a message below and take the
        first step toward a healthier you.
      </p>
    </header>

    <div class="grid md:grid-cols-5 gap-12 max-w-5xl mx-auto mt-16">
      <div class="md:col-span-2">
        <h2 class="font-serif text-2xl font-semibold text-ink-900">Connect</h2>
        <ul class="mt-5 space-y-4 text-ink-500">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 mt-0.5 text-brand-500 shrink-0">
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <div>
              <p class="text-xs font-medium tracking-widest uppercase text-ink-400">
                Phone
              </p>
              <a href="tel:+918088867097" class="hover:text-brand-600">
                +91 80888 67097
              </a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 mt-0.5 text-brand-500 shrink-0">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <div>
              <p class="text-xs font-medium tracking-widest uppercase text-ink-400">
                Email
              </p>
              <a href="mailto:rohanc922@gmail.com" class="hover:text-brand-600">
                rohanc922@gmail.com
              </a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 mt-0.5 text-brand-500 shrink-0">
              <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <div>
              <p class="text-xs font-medium tracking-widest uppercase text-ink-400">
                Based in
              </p>
              <p>Bengaluru, Karnataka · India</p>
              <p class="text-xs text-ink-400 mt-0.5">
                Online consultations worldwide
              </p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 mt-0.5 text-brand-500 shrink-0">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
              <line x1="16" x2="16" y1="2" y2="6"></line>
              <line x1="8" x2="8" y1="2" y2="6"></line>
              <line x1="3" x2="21" y1="10" y2="10"></line>
            </svg>
            <div>
              <p class="text-xs font-medium tracking-widest uppercase text-ink-400">
                Schedule
              </p>
              <a href="/book" class="hover:text-brand-600">
                Book a consultation directly
              </a>
            </div>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
