---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import Cta from "@/components/cta.astro";
---

<Layout
  title="Our Philosophy"
  description="Our philosophy at NutriwithRohan — evidence-based nutrition, customized to you, with goal setting and accountability as the foundation of sustainable results."
>
  <Container>
    <article class="max-w-3xl mx-auto mt-12 lg:mt-20">
      <header>
        <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
          Our Philosophy
        </p>
        <h1
          class="mt-4 font-serif text-5xl lg:text-6xl font-semibold text-ink-900 tracking-tight">
          Health, built on what works for <em class="text-brand-600 not-italic"
            >you</em
          >.
        </h1>
      </header>

      <div class="prose prose-lg mt-10 max-w-none">
        <p class="text-xl leading-relaxed text-ink-700">
          At <strong>NutriwithRohan Wellness Fitness</strong>, our focus is on
          helping our clients achieve their health and wellness goals through
          nutrition. We believe that goal setting and accountability are key
          factors in achieving sustainable results.
        </p>
        <p class="text-lg leading-relaxed text-ink-500">
          Our programmes are rooted in evidence-based practices and customized
          to meet our clients' unique needs. Our team comprises certified
          nutritionists and dietitians who are ever-ready to provide expert
          guidance in the formulation of nutritional plans. We work with our
          clients to develop strategies that empower them to use their diet to
          improve their health and wellbeing.
        </p>
      </div>

      <section class="mt-16">
        <h2 class="font-serif text-3xl font-semibold text-ink-900">Our Process</h2>
        <ol class="mt-8 space-y-6">
          <li class="flex gap-5">
            <div
              class="shrink-0 w-9 h-9 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-serif font-semibold">
              1
            </div>
            <div>
              <h3 class="font-serif text-xl font-semibold text-ink-900">
                Initial consultation
              </h3>
              <p class="mt-1 text-ink-500 leading-relaxed">
                We start by assessing your health goals, medical history, and
                lifestyle in depth — no shortcuts.
              </p>
            </div>
          </li>
          <li class="flex gap-5">
            <div
              class="shrink-0 w-9 h-9 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-serif font-semibold">
              2
            </div>
            <div>
              <h3 class="font-serif text-xl font-semibold text-ink-900">
                Personalized plan
              </h3>
              <p class="mt-1 text-ink-500 leading-relaxed">
                We design a nutrition plan that reflects your dietary
                preferences, food sensitivities, and the realities of your
                schedule — so it's actually sustainable.
              </p>
            </div>
          </li>
          <li class="flex gap-5">
            <div
              class="shrink-0 w-9 h-9 rounded-full bg-brand-50 text-brand-600 flex items-center justify-center font-serif font-semibold">
              3
            </div>
            <div>
              <h3 class="font-serif text-xl font-semibold text-ink-900">
                Ongoing support
              </h3>
              <p class="mt-1 text-ink-500 leading-relaxed">
                We monitor your progress, refine the plan as your body and
                routine change, and stay accountable with you every step of the
                way.
              </p>
            </div>
          </li>
        </ol>
      </section>
    </article>

    <Cta />
  </Container>
</Layout>
