---
import Container from "@/components/container.astro";
import Layout from "@/layouts/Layout.astro";
import Cta from "@/components/cta.astro";
import BrandMark from "@/components/brandmark.astro";
import { Image } from "astro:assets";
import pumpkinSalad from "@/assets/food-pumpkin-salad.png";
import tofuBowl from "@/assets/food-tofu-bowl.png";
---

<Layout
  title="Our Philosophy"
  description="Our philosophy at NutriwithRohan — evidence-based nutrition, customized to you, with goal setting and accountability as the foundation of sustainable results."
>
  <div class="philosophy-bg">
    <Container>
      <header class="max-w-3xl mx-auto text-center pt-12 pb-8 lg:pt-20 lg:pb-12">
        <p class="text-xs font-medium tracking-widest uppercase text-brand-600">
          Our Approach
        </p>
        <h1
          class="mt-4 font-serif text-5xl lg:text-6xl font-semibold text-ink-900 tracking-tight">
          Health, built on what works for <em
            class="text-brand-600 not-italic">you</em>.
        </h1>
      </header>

      <!-- Section 1: image left, text right -->
      <article class="philosophy-row grid lg:grid-cols-2 gap-0 max-w-6xl mx-auto rounded-3xl overflow-hidden bg-cream-50 shadow-lg">
        <div class="aspect-[4/3] lg:aspect-auto lg:min-h-[28rem]">
          <Image
            src={pumpkinSalad}
            alt="Roasted pumpkin and spinach salad bowl — wholesome, balanced, real food."
            widths={[480, 720, 1024]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            format="avif"
            quality={82}
            class="w-full h-full object-cover"
          />
        </div>
        <div class="p-8 md:p-12 lg:p-16 flex flex-col justify-center">
          <h2 class="font-serif text-3xl md:text-4xl font-semibold text-ink-900">
            Our Philosophy
          </h2>
          <div class="mt-5 space-y-4 text-ink-500 leading-relaxed">
            <p class="text-lg text-ink-700">
              At <BrandMark /> <strong>Wellness Fitness</strong>, our focus is
              on helping our clients achieve their health and wellness goals
              through nutrition. We believe that goal setting and
              accountability are key factors in achieving sustainable results.
            </p>
            <p>
              Our programmes are rooted in evidence-based practices and
              customized to meet our clients' unique needs. Our team comprises
              certified nutritionists and dietitians who are ever-ready to
              provide expert guidance in the formulation of nutritional plans.
              We work with our clients to develop strategies that empower them
              to use their diet to improve their health and wellbeing.
            </p>
          </div>
        </div>
      </article>

      <!-- Section 2: text left, image right -->
      <article class="philosophy-row mt-10 grid lg:grid-cols-2 gap-0 max-w-6xl mx-auto rounded-3xl overflow-hidden bg-cream-50 shadow-lg">
        <div class="p-8 md:p-12 lg:p-16 flex flex-col justify-center order-2 lg:order-1">
          <h2 class="font-serif text-3xl md:text-4xl font-semibold text-ink-900">
            Our Process
          </h2>
          <div class="mt-5 space-y-4 text-ink-500 leading-relaxed">
            <p class="text-lg text-ink-700">
              Our process begins with an initial consultation, where we assess
              your health goals, medical history, and lifestyle.
            </p>
            <p>
              Based on this assessment, we create a personalized nutrition
              plan that addresses your specific needs. We take into account
              your dietary preferences, food sensitivities, and lifestyle
              factors to create a plan that is realistic and sustainable.
            </p>
            <p>
              We provide ongoing support and guidance to help you stay on
              track and achieve your goals. We monitor your progress and make
              adjustments as needed to ensure your success. Our goal is to
              help you achieve optimal health and well-being through
              personalized nutrition.
            </p>
          </div>
        </div>
        <div class="aspect-[4/3] lg:aspect-auto lg:min-h-[28rem] order-1 lg:order-2">
          <Image
            src={tofuBowl}
            alt="Vibrant grain bowl with greens, tofu, blueberries — flexible, real-food nutrition."
            widths={[480, 720, 1024]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            format="avif"
            quality={82}
            class="w-full h-full object-cover"
          />
        </div>
      </article>

      <Cta />
    </Container>
  </div>
</Layout>

<style>
  /* Soft warm cream background with a subtle organic texture echoing the leafy
     dappled-light feel of the original Wix layout. SVG inline so no asset request. */
  .philosophy-bg {
    position: relative;
    background:
      radial-gradient(
        circle at 12% 18%,
        var(--color-brand-100) 0%,
        transparent 38%
      ),
      radial-gradient(
        circle at 88% 70%,
        var(--color-cream-200) 0%,
        transparent 45%
      ),
      var(--color-cream-100);
    padding-bottom: 4rem;
  }
  .philosophy-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200' viewBox='0 0 200 200'><g fill='%233F6B4F' fill-opacity='0.04'><path d='M30 40c20-10 30 10 50 0s30-20 50-10 30 30 10 40-30-10-50 0-30 20-50 10-30-30-10-40z'/><path d='M100 130c10-5 20 5 30 0s15-10 25-5 15 15 5 20-15-5-25 0-15 10-25 5-10-15-10-20z'/></g></svg>");
    background-repeat: repeat;
    background-size: 280px 280px;
    opacity: 0.6;
    pointer-events: none;
  }
  .philosophy-row {
    position: relative;
    z-index: 1;
  }
</style>
